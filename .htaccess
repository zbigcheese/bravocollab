Options -Indexes

# Google OAuth callback receives query values like "code=4/0Ae…" with raw
# slashes that match default ModSecurity / OWASP CRS injection rules and
# get blocked at the WAF before PHP even runs. Disable ModSecurity for
# this single request only. Both module names are tried so it works on
# cPanel servers (mod_security2) and on rare older hosts (mod_security).
<IfModule mod_security2.c>
    <If "%{QUERY_STRING} =~ /page=google_callback/">
        SecRuleEngine Off
    </If>
</IfModule>
<IfModule mod_security.c>
    <If "%{QUERY_STRING} =~ /page=google_callback/">
        SecFilterEngine Off
    </If>
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "same-origin"
</IfModule>

# Block access to sensitive directories and files
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/ - [F,L]
    RewriteRule ^core/ - [F,L]
    RewriteRule ^models/ - [F,L]
    RewriteRule ^controllers/ - [F,L]
    RewriteRule ^sql/ - [F,L]
    RewriteRule ^views/ - [F,L]
    RewriteRule ^sessions/ - [F,L]
</IfModule>

# Block sensitive file extensions
<FilesMatch "\.(sql|md|log|sh|bak|env)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>
